new file mode 100644
index 0000000..8b3c949
--- /dev/null
+++ b/actions/compute-version/action.yml
@@ -0,0 +1,38 @@
+name: Compute next semantic version
+description: Computes the next v<major>.<minor>.<patch> tag and corresponding moving major tag.
+
+outputs:
+  next_tag:
+    description: Next full semantic version tag (e.g. v0.1.1)
+    value: ${{ steps.compute.outputs.next_tag }}
+  major_tag:
+    description: Moving major tag (e.g. v0)
+    value: ${{ steps.compute.outputs.major_tag }}
+
+runs:
+  using: "composite"
+  steps:
+    - name: Compute next patch version from existing tags
+      id: compute
+      shell: bash
+      run: |
+        set -euo pipefail
+
+        semver_tags="$(git tag -l | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' || true)"
+
+        if [ -z "${semver_tags}" ]; then
+          next_tag="v0.1.0"
+        else
+          latest_tag="$(printf "%s\n" "${semver_tags}" | sort -V | tail -n1)"
+          version="${latest_tag#v}"
+
+          IFS='.' read -r major minor patch <<< "${version}"
+          patch=$((patch + 1))
+
+          next_tag="v${major}.${minor}.${patch}"
+        fi
+
+        major_tag="v$(echo "${next_tag#v}" | cut -d. -f1)"
+
+        echo "next_tag=${next_tag}" >> "$GITHUB_OUTPUT"
+        echo "major_tag=${major_tag}" >> "$GITHUB_OUTPUT"
diff --git a/.github/workflows/versioning.yml b/.github/workflows/versioning.yml
new file mode 100644
index 0000000..26ce3ff
--- /dev/null
+++ b/.github/workflows/versioning.yml
@@ -0,0 +1,96 @@
+name: Versioning
+
+on:
+  push:
+    branches:
+      - main
+  pull_request:
+
+concurrency:
+  group: versioning-${{ github.event_name }}-${{ github.ref }}
+  # push-to-main: never cancel (every push must get a tag)
+  # pull_request: cancel stale runs (dry-run only, no side effects)
+  cancel-in-progress: ${{ github.event_name == 'pull_request' }}
+
+permissions:
+  contents: write
+
+jobs:
+  version:
+    # recursion/bot guard:
+    # - run on PRs always (dry-run only)
+    # - run on push to main only if actor is not github-actions[bot]
+    if: |
+      github.event_name == 'pull_request' ||
+      (github.event_name == 'push' &&
+       github.ref == 'refs/heads/main' &&
+       github.actor != 'github-actions[bot]')
+    runs-on: ubuntu-latest
+
+    steps:
+      - name: Checkout (full history + tags)
+        uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+
+      - name: Ensure tags are up to date
+        run: git fetch --force --tags
+
+      - name: Compute next version
+        id: compute
+        uses: ./actions/compute-version
+
+      - name: Dry-run summary (PR)
+        if: github.event_name == 'pull_request'
+        run: |
+          {
+            echo "## Versioning dry-run"
+            echo ""
+            echo "- event: pull_request"
+            echo "- would create next tag: \`${{ steps.compute.outputs.next_tag }}\`"
+            echo "- would move major tag: \`${{ steps.compute.outputs.major_tag }}\`"
+            echo ""
+            echo "_No tags were pushed in PR mode._"
+          } >> "$GITHUB_STEP_SUMMARY"
+
+      - name: Create/update tags (push to main)
+        if: github.event_name == 'push'
+        env:
+          NEXT_TAG: ${{ steps.compute.outputs.next_tag }}
+          MAJOR_TAG: ${{ steps.compute.outputs.major_tag }}
+        run: |
+          set -euo pipefail
+
+          # Idempotency check: if NEXT_TAG already exists remotely, ensure MAJOR_TAG points to it and exit.
+          if git ls-remote --exit-code --tags origin "refs/tags/${NEXT_TAG}" >/dev/null 2>&1; then
+            echo "Tag ${NEXT_TAG} already exists on origin. Ensuring ${MAJOR_TAG} points to ${NEXT_TAG}."
+            git fetch --force --tags
+
+            git tag -f "${MAJOR_TAG}" "${NEXT_TAG}"
+            git push origin "${MAJOR_TAG}" --force
+
+            {
+              echo "## Versioning result"
+              echo ""
+              echo "- next tag already exists: \`${NEXT_TAG}\`"
+              echo "- ensured major tag points to: \`${MAJOR_TAG}\`"
+            } >> "$GITHUB_STEP_SUMMARY"
+            exit 0
+          fi
+
+          echo "Creating version tag: ${NEXT_TAG}"
+          git tag "${NEXT_TAG}"
+
+          echo "Updating moving major tag: ${MAJOR_TAG}"
+          git tag -f "${MAJOR_TAG}"
+
+          echo "Pushing tags"
+          git push origin "${NEXT_TAG}"
+          git push origin "${MAJOR_TAG}" --force
+
+          {
+            echo "## Versioning result"
+            echo ""
+            echo "- created tag: \`${NEXT_TAG}\`"
+            echo "- moved major tag: \`${MAJOR_TAG}\`"
+          } >> "$GITHUB_STEP_SUMMARY"
